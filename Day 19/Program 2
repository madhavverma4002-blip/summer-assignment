public class MatrixSubtraction {
    public static void main(String[] args) {
        int[][] A = {
            {7, 8, 9},
            {10, 11, 12}
        };

        int[][] B = {
            {1, 2, 3},
            {4, 5, 6}
        };

        int[][] diff = new int[2][3];

        // Subtract matrices
        for (int i = 0; i < 2; i++) {
            for (int j = 0; j < 3; j++) {
                diff[i][j] = A[i][j] - B[i][j];
            }
        }

        System.out.println("Difference of matrices:");

        for (int i = 0; i < 2; i++) {
            for (int j = 0; j < 3; j++) {
                System.out.print(diff[i][j] + " ");
            }
            System.out.println();
        }
    }
}
